---
config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	router(router)
	billing(billing)
	engineering(engineering)
	docs(docs)
	fallback(fallback)
	escalation(escalation)
	__end__([<p>__end__</p>]):::last
	__start__ --> router;
	router -.-> billing;
	router -.-> docs;
	router -.-> engineering;
	router -.-> escalation;
	router -.-> fallback;
	billing --> __end__;
	docs --> __end__;
	engineering --> __end__;
	escalation --> __end__;
	fallback --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
