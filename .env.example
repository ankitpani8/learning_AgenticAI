GEMINI_API_KEY= [Paste your Gemini API key here]
# Optional: Anthropic API key for Claude.
# Note: a claude.ai subscription does NOT include API credits.
# Add credit at console.anthropic.com -> Billing.
ANTHROPIC_API_KEY= [Paste your Anthropic API key here]
# Hugging Face token for accessing models and datasets. No HF project needed in this course — 
# it's just an optional token for anonymous-vs-authenticated rate limiting in module 4 (Memory and RAG).
# You can get one for free at https://huggingface.co/settings/tokens 
HF_TOKEN=your_hf_token_here
# For Observability and Tracing with LangSmith
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=your_project_name_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com